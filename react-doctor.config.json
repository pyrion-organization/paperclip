          "src/pages/IssueDetail.tsx",
          "ui/src/pages/IssueDetail.tsx",
          "src/plugins/launcher-runtime.tsx",
          "ui/src/plugins/launcher-runtime.tsx"
        ],
        "rules": ["react-doctor/async-await-in-loop"]
      },
      {
        "comment": "runtime plugin module loaded from a blob URL — a static import literal is impossible by design.",
        "files": [
          "src/plugins/slots-loader.ts",
          "ui/src/plugins/slots-loader.ts"
        ],
        "rules": ["react-doctor/no-dynamic-import-path"]
      },
      {
        "comment": "the await must precede the guard: the guard reads a ref mutated during the awaited save.",
        "files": [
          "src/hooks/useAutosaveIndicator.ts",
          "ui/src/hooks/useAutosaveIndicator.ts"
        ],
        "rules": ["react-doctor/async-defer-await"]
      },
      {
        "comment": "external-system sync effects (scroll-into-view, textarea autoresize, localStorage persistence, URL back/forward) — not harmful state chains.",
        "files": [
          "src/components/IssueDocumentsSection.tsx",
          "ui/src/components/IssueDocumentsSection.tsx",
          "src/components/OnboardingWizard.tsx",
          "ui/src/components/OnboardingWizard.tsx",
          "src/pages/CompanyExport.tsx",
          "ui/src/pages/CompanyExport.tsx",
          "src/pages/Inbox.tsx",
          "ui/src/pages/Inbox.tsx"
        ],
        "rules": ["react-doctor/no-effect-chain"]
      },
      {
        "comment": "intentional child->parent action-callback control pattern (e.g. AgentConfigForm hands its save/dirty/cancel actions to the page toolbar). Deliberate, not a state-lift smell.",
        "files": [
          "src/components/AgentConfigForm.tsx",
          "ui/src/components/AgentConfigForm.tsx",
          "src/components/IssueThreadInteractionCard.tsx",
          "ui/src/components/IssueThreadInteractionCard.tsx",
