          "src/pages/Companies.tsx",
          "ui/src/pages/Companies.tsx",
          "src/pages/CompanyInstructions.tsx",
          "ui/src/pages/CompanyInstructions.tsx",
          "src/pages/Inbox.tsx",
          "ui/src/pages/Inbox.tsx",
          "src/pages/OrgChart.tsx",
          "ui/src/pages/OrgChart.tsx",
          "src/plugins/launcher-shell.tsx",
          "ui/src/plugins/launcher-shell.tsx"
        ],
        "rules": ["react-doctor/prefer-tag-over-role"]
      },
      {
